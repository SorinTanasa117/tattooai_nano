# InkFrame widget port
PORT=5173

# Replace COMFYUI_URL with your chosen Nano Banana 2 provider endpoints 
# (e.g., Google Vertex AI, Firebase AI Logic, or Google AI Studio)
AI_PROVIDER_API_KEY=AQ.Ab....
AI_MODEL_NAME=gemini-3.1-flash-image

# Render timeout (Nano Banana 2 typically yields results in 10-30 seconds, 
# down from your CPU ComfyUI timeout of ~2.5 hours)
RENDER_TIMEOUT_MS=30000

# Cloudflare R2
R2_ACCOUNT_ID=def...
R2_ACCESS_KEY_ID=8e979...
R2_SECRET_ACCESS_KEY=7b143...
R2_BUCKET_NAME=tattooapp
