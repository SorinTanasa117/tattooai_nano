# InkFrame widget port (default 5173)
PORT=5173

# ComfyUI base URL — the server will hit /upload/image, /prompt, /history, /view
COMFYUI_URL=http://127.0.0.1:8188

# Universal ComfyUI workflow template (relative or absolute).
# If this file is missing, InkFrame will auto-build it from SOURCE_WORKFLOW.
WORKFLOW_FILE=./merged-tattoo-rotator-v5.json

# Developer-authored upstream workflow. The build_template.py script reads
# this and writes WORKFLOW_FILE with sentinel placeholders.
SOURCE_WORKFLOW=./final.json

# Template builder (defaults to scripts/build_template.py)
BUILD_SCRIPT=./scripts/build_template.py

# Patcher that injects live payload values into the template (defaults to scripts/patch_workflow.py)
PATCH_SCRIPT=./scripts/patch_workflow.py

# Max time to wait for a ComfyUI render, in milliseconds (default 180000 = 3 min)
RENDER_TIMEOUT_MS=180000
