# InkFrame widget port (default 5173)
PORT=5173

# ComfyUI base URL - the server will hit /upload/image, /prompt, /history, /view
COMFYUI_URL=http://127.0.0.1:8188

# Path to the ComfyUI workflow JSON (relative or absolute)
WORKFLOW_FILE=./merged-tattoo-rotator-v6.json

# Path to the Python patcher (relative or absolute)
PATCH_SCRIPT=./scripts/patch_workflow.py

# Max time to wait for a ComfyUI render, in milliseconds.
# Default 10000000 (= 10000s / ~2h47m) -- CPU systems regularly take
# 5-10 minutes for a Flux2 inpaint + IP-Adapter pass. Lower this on a
# GPU machine if you want faster failure feedback.
RENDER_TIMEOUT_MS=10000000
